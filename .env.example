DEBUG=True
SECRET_KEY=change-me-in-production-use-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1

DATABASE_URL=postgres://cpms_user:cpms_password@localhost:5432/kemelecpms_db

REDIS_URL=redis://localhost:6379/0

MEDIA_ROOT=/home/user/kemelecpms/media
STATIC_ROOT=/home/user/kemelecpms/staticfiles

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@kemeleconstruction.com.pg

# AWS S3 (optional – leave blank to use local media)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Site
SITE_URL=http://localhost:8000
COMPANY_NAME=Kemele Construction

# SMS Gateway (Digicel PNG or compatible HTTP gateway — leave blank to disable)
SMS_GATEWAY_URL=
SMS_API_KEY=
SMS_FROM_NUMBER=KEMELE

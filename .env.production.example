# =============================================================================
# Kemele Construction CPMS — Production Environment Template
# =============================================================================
# Copy this file to /home/kemelecpms/kemelecpms/.env and fill in real values:
#     cp .env.production.example .env
#
# Use with DJANGO_SETTINGS_MODULE=config.settings.production
#
# Variables marked [REQUIRED] have NO default in production settings — the
# application will refuse to start (ImproperlyConfigured) if they are missing
# or left at an insecure placeholder value.
# =============================================================================

# --- Core Django ------------------------------------------------------------

# [REQUIRED] Long random string (50+ chars). Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# [REQUIRED] Must be False in production.
DEBUG=False

# [REQUIRED] Comma-separated hostnames served by this instance.
ALLOWED_HOSTS=cpms.kemeleconstruction.com.pg,www.cpms.kemeleconstruction.com.pg

# --- Database ---------------------------------------------------------------

# [REQUIRED] PostgreSQL connection URL.
DATABASE_URL=postgres://cpms_user:CHANGE_THIS_PASSWORD@localhost:5432/kemelecpms_db

# --- Redis / Cache ----------------------------------------------------------

# [REQUIRED] Used for the Django cache, cached sessions, and as the default
# Celery broker/result backend.
REDIS_URL=redis://localhost:6379/0

# --- Static & Media Paths ---------------------------------------------------

# [REQUIRED for deployment consistency] Must match the nginx config
# (nginx/kemelecpms.conf), which serves these exact paths.
# deploy/deploy.sh runs collectstatic, which outputs to STATIC_ROOT.
STATIC_ROOT=/home/kemelecpms/staticfiles
MEDIA_ROOT=/home/kemelecpms/media

# --- Email (SMTP) -----------------------------------------------------------

# Production uses django.core.mail.backends.smtp.EmailBackend (hardcoded in
# config/settings/production.py). Set credentials below.
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@kemeleconstruction.com.pg

# --- SMS / WhatsApp Gateways ------------------------------------------------

# Digicel PNG or any compatible HTTP SMS gateway. Leave blank to disable SMS.
SMS_GATEWAY_URL=
SMS_API_KEY=
SMS_FROM_NUMBER=KEMELE
WHATSAPP_GATEWAY_URL=
WHATSAPP_API_KEY=

# --- Site / Branding --------------------------------------------------------

# Public base URL of the site (used in emails/notification links).
SITE_URL=https://cpms.kemeleconstruction.com.pg
COMPANY_NAME=Kemele Construction

# --- Celery -----------------------------------------------------------------

# Default to REDIS_URL if unset; override only if using a separate broker.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
